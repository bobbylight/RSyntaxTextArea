<YYINITIAL> "tkerror"				{ addToken(TokenTypes.RESERVED_WORD); }
<YYINITIAL> "tkwait"				{ addToken(TokenTypes.RESERVED_WORD); }
<YYINITIAL> "toplevel"				{ addToken(TokenTypes.RESERVED_WORD); }
